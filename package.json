{
  "name": "toss-enterprise",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "agents/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/website",
    "build": "npm run build --workspace=apps/website",
    "lint": "npm run lint --workspace=apps/website",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "type-check": "npm run type-check --workspace=apps/website",
    "website": "npm run dev --workspace=apps/website"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
